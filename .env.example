# Provider credentials. Fill in only the providers you plan to use.
# Never commit real API keys.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
BASETEN_API_KEY=""

# Optional: LangSmith tracing
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=""
# LANGSMITH_PROJECT="acp-server"

# Optional model catalog controls.
# ACP_DEFAULT_MODEL=openai:gpt-5.6-terra
# ACP_ENABLED_MODEL_PROVIDERS=anthropic,openai,baseten
# ACP_ROUTER_DEFAULT=openai_terra
# ACP_SUBAGENT_BASE_MODEL=openai:gpt-5.6-terra
# If unset, the router base model follows the effective router default.
# ACP_DISABLE_DEFAULT_MODELS=false
# ACP_MODEL_CONFIG=
